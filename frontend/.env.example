# ====================================================================
# SENTINELTRAFFIC FRONTEND CONFIGURATION
# ====================================================================
#
# When deploying to Vercel:
# Add this environment variable in the Vercel Dashboard -> Project Settings -> Environment Variables.
#
# BACKEND_URL=https://sentinel-traffic-backend.onrender.com
#
# Note: If no environment variable is provided, the build script will automatically
# default to using the local API domain (when running on localhost) and fall back
# to the predefined Render URL in production.
#
# To test build locally:
# 1. Create a .env file here and set: BACKEND_URL=http://localhost:8000
# 2. Run 'npm run build' inside the frontend directory.
#
BACKEND_URL=
